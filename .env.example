# Postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://bronco:changeme@localhost:5432/bronco

# Redis
REDIS_URL=redis://localhost:6379

# Encryption key for DB credentials (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# IMAP (Google Workspace)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=support@yourdomain.com
IMAP_PASSWORD=

# SMTP (Gmail — uses same app password as IMAP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@yourdomain.com
SMTP_PASSWORD=
SMTP_FROM=support@yourdomain.com

# API auth (single operator key)
API_KEY=

# JWT secret for control panel auth (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# MCP Database Server (runs in Azure App Service on same vnet as client Azure SQL MIs)
# copilot-api calls this for DB tool operations; Claude Code connects to /mcp endpoint
MCP_DATABASE_URL=https://your-mcp-app.azurewebsites.net
MCP_AUTH_TOKEN=

# Caddy / Control Panel
# Set to your Tailscale hostname (e.g. hugo.tail1234.ts.net) for auto-TLS,
# or leave as localhost for plain HTTP. Caddy fetches *.ts.net certs
# automatically via the mounted tailscaled socket.
DOMAIN=localhost

# Repo workspace — how long to keep cloned repos before automatic cleanup (days).
# Applies to both imap-worker (bare clones for analysis) and issue-resolver (full clones).
# Workspace paths are set in docker-compose.yml with persistent named volumes.
# REPO_RETENTION_DAYS=14

# QNAP mount path — must be mounted on the Linux VM host FIRST (NFS or SMB)
# Containers bind-mount this path from the host. Do NOT mount NFS/SMB inside containers.
QNAP_MOUNT_PATH=/mnt/qnap
