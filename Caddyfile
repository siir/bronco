(routes) {
  # API requests → copilot-api
  handle /api/* {
    reverse_proxy copilot-api:3000
  }

  # Control Panel SPA
  handle_path /cp* {
    root * /srv/control-panel
    try_files {path} /index.html
    file_server
  }

  # Client Ticket Portal SPA
  handle_path /portal* {
    root * /srv/ticket-portal
    try_files {path} /index.html
    file_server
  }

  # Root → redirect to control panel
  handle {
    redir / /cp/ permanent
    redir /* /cp{uri} permanent
  }
}

# Public access via Cloudflare Tunnel (TLS terminated at Cloudflare edge).
# See README.md → Deployment → Public access via Cloudflare Tunnel.
http://itrack.siirial.com {
  import routes
}

# Direct access via Tailscale (plain HTTP over the Tailscale-encrypted tunnel).
http://100.106.127.1 {
  import routes
}
