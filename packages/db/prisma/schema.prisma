// --- Ticket Routes (customizable ticket processing pipelines) ---
// Defines ordered sequences of processing steps that tickets go through.
// INGESTION routes enrich + create tickets from a source (matched by source).
// ANALYSIS routes investigate existing tickets (matched by category).
// Routes can be global (clientId=null) or client-specific, and optionally
// tied to a specific TicketCategory. A default route is used when no
// category-specific route matches.

model TicketRoute {
  id          String          @id @default(uuid()) @db.Uuid
  name        String
  description String?
  /// AI-generated summary describing what this route does — used for route selection.
  summary     String?
  /// INGESTION routes enrich + create tickets from a source. ANALYSIS routes investigate existing tickets.
  routeType   RouteType       @default(ANALYSIS) @map("route_type")
  category    TicketCategory?
  /// Optional ticket source filter — only matches tickets with this source. Null means any source.
  source      TicketSource?   @map("source")
  clientId    String?         @map("client_id") @db.Uuid
  isActive    Boolean         @default(true) @map("is_active")
  isDefault   Boolean         @default(false) @map("is_default")
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  client        Client?           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  steps         TicketRouteStep[]
  ingestionRuns IngestionRun[]

  @@unique([name, clientId])
  @@index([routeType, category, clientId, source, isActive])
  @@index([isDefault, isActive])
  @@index([clientId])
  @@map("ticket_routes")
}

model TicketRouteStep {
  id               String   @id @default(uuid()) @db.Uuid
  routeId          String   @map("route_id") @db.Uuid
  stepOrder        Int      @map("step_order")
  name             String
  /// The built-in step type to execute (maps to RouteStepType in shared-types).
  stepType         RouteStepType @map("step_type")
  /// Optional AI task type override (e.g. use BUG_ANALYSIS instead of DEEP_ANALYSIS).
  taskTypeOverride String?  @map("task_type_override")
  /// Optional prompt key override for the AI step.
  promptKeyOverride String? @map("prompt_key_override")
  /// Step-specific configuration (JSON).
  config           Json?
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  route TicketRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([routeId, stepOrder])
  @@index([routeId, isActive])
  @@map("ticket_route_steps")
}

// --- Email Processing Logs (tracks every inbound email and its classification/processing result) ---

model EmailProcessingLog {
  id              String    @id @default(uuid()) @db.Uuid
  messageId       String    @map("message_id")
  from            String
  fromName        String?   @map("from_name")
  subject         String
  receivedAt      DateTime  @map("received_at")
  classification  String    @map("classification")  // TICKET_WORTHY, AUTO_REPLY, NOISE, THREAD_REPLY
  status          String    @default("processed") @map("status")  // processed, failed, retried, discarded
  clientId        String?   @map("client_id") @db.Uuid
  ticketId        String?   @map("ticket_id") @db.Uuid
  errorMessage    String?   @map("error_message")
  processingMs    Int?      @map("processing_ms")
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")

  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  ticket          Ticket?   @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@unique([messageId])
  @@index([status])
  @@index([classification])
  @@index([clientId, createdAt])
  @@index([createdAt])
  @@map("email_processing_logs")
}

// ── Client Memory ──────────────────────────────────────────────────
// Per-client operational knowledge that guides AI analysis.
// Entries are automatically injected into AI context when a ticket
// is processed for the matching client (and optionally category).

model ClientMemory {
  id         String          @id @default(uuid()) @db.Uuid
  clientId   String          @map("client_id") @db.Uuid
  title      String
  /// CONTEXT | PLAYBOOK | TOOL_GUIDANCE
  memoryType String          @map("memory_type")
  category   TicketCategory?
  /// Free-form tags for flexible matching (e.g. "blocking", "deadlocks").
  tags       String[]        @default([])
  /// Markdown content — the actual knowledge injected into AI prompts.
  content    String          @db.Text
  isActive   Boolean         @default(true) @map("is_active")
  sortOrder  Int             @default(0) @map("sort_order")
  /// MANUAL | AI_LEARNED
  source     String          @default("MANUAL")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, title])
  @@index([clientId, isActive])
  @@index([clientId, category])
  @@map("client_memories")
}

// ── Scheduled Probes ────────────────────────────────────────────────
// Cron-driven MCP tool executions that create tickets when results
// are actionable.

model ScheduledProbe {
  id             String          @id @default(uuid()) @db.Uuid
  clientId       String          @map("client_id") @db.Uuid
  integrationId  String?         @map("integration_id") @db.Uuid
  name           String
  description    String?
  toolName       String          @map("tool_name")
  toolParams     Json            @default("{}") @map("tool_params")
  cronExpression    String          @map("cron_expression")
  scheduleHour      Int?            @map("schedule_hour")
  scheduleMinute    Int?            @default(0) @map("schedule_minute")
  scheduleDaysOfWeek String?        @map("schedule_days_of_week")
  scheduleTimezone  String?         @map("schedule_timezone")
  category          TicketCategory?
  /// create_ticket | email_direct | silent
  action         String          @default("create_ticket")
  actionConfig   Json?           @map("action_config")
  isActive       Boolean         @default(true) @map("is_active")
  lastRunAt      DateTime?       @map("last_run_at")
  lastRunStatus  String?         @map("last_run_status")
  lastRunResult  String?         @map("last_run_result") @db.Text
  retentionDays    Int           @default(30) @map("retention_days")
  retentionMaxRuns Int           @default(100) @map("retention_max_runs")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  integration ClientIntegration? @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  runs        ProbeRun[]

  @@index([clientId, isActive])
  @@map("scheduled_probes")
}

// ── Probe Run History ─────────────────────────────────────────────────
// Each execution of a ScheduledProbe creates a ProbeRun with step-level detail.

model ProbeRun {
  id          String    @id @default(uuid()) @db.Uuid
  probeId     String    @map("probe_id") @db.Uuid
  /// pending | running | success | error | skipped
  status      String
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  durationMs  Int?      @map("duration_ms")
  result      String?   @db.Text
  error       String?   @db.Text
  /// schedule | manual
  triggeredBy String    @map("triggered_by")

  probe ScheduledProbe @relation(fields: [probeId], references: [id], onDelete: Cascade)
  steps ProbeRunStep[]

  @@index([probeId, startedAt(sort: Desc)])
  @@map("probe_runs")
}

model ProbeRunStep {
  id          String    @id @default(uuid()) @db.Uuid
  runId       String    @map("run_id") @db.Uuid
  stepOrder   Int       @map("step_order")
  stepName    String    @map("step_name")
  /// pending | running | success | error | skipped
  status      String
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  detail      String?   @db.Text
  error       String?   @db.Text

  run ProbeRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, stepOrder])
  @@map("probe_run_steps")
}

// ── Ingestion Run History ─────────────────────────────────────────────
// Each execution of the ingestion pipeline creates an IngestionRun with
// step-level detail for full observability.

model IngestionRun {
  id          String    @id @default(uuid()) @db.Uuid
  jobId       String    @map("job_id")
  source      TicketSource @map("source")
  clientId    String    @map("client_id") @db.Uuid
  routeId     String?   @map("route_id") @db.Uuid
  routeName   String?   @map("route_name")
  /// processing | success | error | no_route
  status      String    @default("processing") @map("status")
  ticketId    String?   @map("ticket_id") @db.Uuid
  error       String?   @db.Text
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  client Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  route  TicketRoute? @relation(fields: [routeId], references: [id], onDelete: SetNull)
  ticket Ticket?      @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  steps  IngestionRunStep[]

  @@index([clientId, startedAt])
  @@index([routeId])
  @@index([status])
  @@index([ticketId])
  @@map("ingestion_runs")
}

model IngestionRunStep {
  id          String    @id @default(uuid()) @db.Uuid
  runId       String    @map("run_id") @db.Uuid
  stepOrder   Int       @map("step_order")
  stepType    String    @map("step_type")
  stepName    String    @map("step_name")
  /// pending | processing | success | error | skipped
  status      String    @default("pending") @map("status")
  output      String?   @db.Text
  error       String?   @db.Text
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  durationMs  Int?      @map("duration_ms")

  run IngestionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, stepOrder])
  @@map("ingestion_run_steps")
}

// --- Notification Preferences (event → channel routing) ---

model NotificationPreference {
  id           String   @id @default(uuid()) @db.Uuid
  event        String   @unique // e.g. TICKET_CREATED, PLAN_READY
  emailEnabled Boolean  @default(true) @map("email_enabled")
  slackEnabled Boolean  @default(false) @map("slack_enabled")
  slackTarget  String?  @map("slack_target") // channel ID, "assigned_operator", "all_operators"
  emailTarget  String?  @map("email_target") // "assigned_operator", "all_operators", or specific email
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

// --- Pending Actions (AI recommendations awaiting operator approval) ---

model PendingAction {
  id          String    @id @default(uuid()) @db.Uuid
  ticketId    String    @map("ticket_id") @db.Uuid
  actionType  String    @map("action_type")
  value       Json
  status      String    @default("pending") // pending, approved, dismissed
  source      String    @default("ai_recommendation")
  resolvedAt  DateTime? @map("resolved_at")
  resolvedBy  String?   @map("resolved_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([status])
  @@map("pending_actions")
}

// --- Slack Conversation Logs (Hugo bot conversation persistence) ---

model SlackConversationLog {
  id                String   @id @default(uuid()) @db.Uuid
  operatorId        String   @map("operator_id") @db.Uuid
  channelId         String   @map("channel_id")
  threadTs          String   @map("thread_ts")
  clientId          String?  @map("client_id") @db.Uuid
  messages          Json
  toolCalls         Json?    @map("tool_calls")
  totalCost         Float?   @map("total_cost")
  totalInputTokens  Int?     @map("total_input_tokens")
  totalOutputTokens Int?     @map("total_output_tokens")
  messageCount      Int      @default(0) @map("message_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  operator Operator @relation(fields: [operatorId], references: [id])
  client   Client?  @relation(fields: [clientId], references: [id])

  @@unique([channelId, threadTs])
  @@index([operatorId])
  @@index([clientId])
  @@index([createdAt])
  @@map("slack_conversation_logs")
}

// --- App Settings (key-value JSON store for app-wide configuration) ---

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
