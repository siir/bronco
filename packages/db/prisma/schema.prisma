generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Users (control panel & client portal accounts) ---

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         UserRole @default(OPERATOR)
  clientId     String?  @map("client_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  client               Client?              @relation(fields: [clientId], references: [id])
  refreshTokens        RefreshToken[]
  filterPresets        TicketFilterPreset[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  jti       String    @unique @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model TicketFilterPreset {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String
  statusFilter   String?  @map("status_filter")
  categoryFilter String?  @map("category_filter")
  clientIdFilter String?  @map("client_id_filter") @db.Uuid
  priorityFilter String?  @map("priority_filter")
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("ticket_filter_presets")
}

// --- Client Portal Users (separate auth from control panel) ---

model ClientUser {
  id           String         @id @default(uuid()) @db.Uuid
  email        String         @unique
  passwordHash String         @map("password_hash")
  name         String
  clientId     String         @map("client_id") @db.Uuid
  userType     ClientUserType @default(USER) @map("user_type")
  isActive     Boolean        @default(true) @map("is_active")
  lastLoginAt  DateTime?      @map("last_login_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  client        Client                   @relation(fields: [clientId], references: [id])
  refreshTokens ClientUserRefreshToken[]

  @@index([clientId])
  @@map("client_users")
}

model ClientUserRefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  jti       String    @unique @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user ClientUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("client_user_refresh_tokens")
}

// --- Operators (multi-operator identity and notification preferences) ---

model Operator {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  name         String
  isActive     Boolean  @default(true) @map("is_active")
  notifyEmail  Boolean  @default(true) @map("notify_email")
  notifySlack  Boolean  @default(false) @map("notify_slack")
  slackUserId  String?  @map("slack_user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assignedTickets    Ticket[]
  approvedJobs       IssueJob[] @relation("ApprovedByOperator")
  slackConversations SlackConversationLog[]

  @@map("operators")
}

// --- Core entities ---

model Client {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  shortCode      String   @unique @map("short_code")
  isActive              Boolean  @default(true) @map("is_active")
  autoRouteTickets      Boolean  @default(true) @map("auto_route_tickets")
  allowSelfRegistration Boolean  @default(false) @map("allow_self_registration")
  aiMode                String   @default("platform") @map("ai_mode")
  notes                String?
  companyProfile       String?  @map("company_profile")
  systemsProfile       String?  @map("systems_profile")
  domainMappings       String[] @default([]) @map("domain_mappings") // e.g. ["altmanplants.com", "altman.com"]
  billingMarkupPercent Float    @default(1.0) @map("billing_markup_percent")
  billingPeriod        String   @default("disabled") @map("billing_period")
  billingAnchorDay     Int      @default(1) @map("billing_anchor_day")
  slackChannelId       String?  @map("slack_channel_id")
  isInternal           Boolean  @default(false) @map("is_internal")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  contacts     Contact[]
  systems      System[]
  tickets      Ticket[]
  codeRepos    CodeRepo[]
  repositories Repository[]
  integrations    ClientIntegration[]
  users           User[]
  clientUsers     ClientUser[]
  promptOverrides PromptOverride[]
  aiModelConfigs  AiModelConfig[]
  systemAnalyses  SystemAnalysis[]
  ticketRoutes    TicketRoute[]
  clientMemories      ClientMemory[]
  scheduledProbes     ScheduledProbe[]
  environments        ClientEnvironment[]
  invoices            Invoice[]
  aiCredentials       ClientAiCredential[]
  ingestionRuns       IngestionRun[]
  emailProcessingLogs EmailProcessingLog[]
  slackConversations  SlackConversationLog[]

  @@map("clients")
}

model ClientEnvironment {
  id                      String   @id @default(uuid()) @db.Uuid
  clientId                String   @map("client_id") @db.Uuid
  name                    String
  tag                     String
  description             String?
  operationalInstructions String?  @map("operational_instructions")
  isDefault               Boolean  @default(false) @map("is_default")
  isActive                Boolean  @default(true) @map("is_active")
  sortOrder               Int      @default(0) @map("sort_order")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  integrations ClientIntegration[]
  codeRepos    CodeRepo[]
  systems      System[]
  tickets      Ticket[]

  @@unique([clientId, tag])
  @@index([clientId])
  @@map("client_environments")
}

model ClientAiCredential {
  id              String   @id @default(uuid()) @db.Uuid
  clientId        String   @map("client_id") @db.Uuid
  provider        String   // "CLAUDE", "OPENAI", "GROK", "LOCAL"
  encryptedApiKey String   @map("encrypted_api_key")
  label           String
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, provider, isActive], map: "client_ai_credentials_client_id_provider_is_active_idx")
  @@map("client_ai_credentials")
}

model Contact {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  name        String
  email       String
  phone       String?
  role        String?
  slackUserId String?  @map("slack_user_id")
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client           Client           @relation(fields: [clientId], references: [id])
  ticketFollowers  TicketFollower[]

  @@map("contacts")
}

// --- Repositories (client source code) ---

model Repository {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  name      String
  url       String
  branch    String   @default("main")
  localPath String?  @map("local_path")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  @@unique([clientId, name])
  @@map("repositories")
}

// --- Database systems (client SQL Servers) ---

model System {
  id                String      @id @default(uuid()) @db.Uuid
  clientId          String      @map("client_id") @db.Uuid
  name              String
  dbEngine          DbEngine    @default(MSSQL) @map("db_engine")
  host              String
  port              Int         @default(1433)
  connectionString  String?     @map("connection_string")
  instanceName      String?     @map("instance_name")
  defaultDatabase   String?     @map("default_database")
  authMethod        AuthMethod  @default(SQL_AUTH) @map("auth_method")
  username          String?
  encryptedPassword String?     @map("encrypted_password")
  useTls            Boolean     @default(true) @map("use_tls")
  trustServerCert   Boolean     @default(false) @map("trust_server_cert")
  connectionTimeout Int         @default(15000) @map("connection_timeout")
  requestTimeout    Int         @default(30000) @map("request_timeout")
  maxPoolSize       Int         @default(5) @map("max_pool_size")
  isActive          Boolean     @default(true) @map("is_active")
  environment       Environment @default(PRODUCTION)
  notes             String?
  lastConnectedAt   DateTime?   @map("last_connected_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  environmentId String? @map("environment_id") @db.Uuid

  client              Client              @relation(fields: [clientId], references: [id])
  clientEnvironment   ClientEnvironment?  @relation(fields: [environmentId], references: [id])
  tickets             Ticket[]
  findings            Finding[]
  queryAuditLogs      QueryAuditLog[]

  @@unique([clientId, name])
  @@index([environmentId])
  @@map("systems")
}

// --- Tickets ---

model Ticket {
  id          String       @id @default(uuid()) @db.Uuid
  clientId    String       @map("client_id") @db.Uuid
  systemId    String?      @map("system_id") @db.Uuid
  subject     String
  description String?
  summary     String?
  status      TicketStatus @default(OPEN)
  priority    Priority     @default(MEDIUM)
  source      TicketSource    @default(MANUAL)
  category    TicketCategory?
  ticketNumber Int             @map("ticket_number")
  metadata        Json?
  externalRef     String?         @map("external_ref")
  reanalysisCount Int             @default(0) @map("reanalysis_count")
  analysisStatus  AnalysisStatus  @default(PENDING) @map("analysis_status")
  analysisError   String?         @map("analysis_error")
  sufficiencyStatus SufficiencyStatus? @map("sufficiency_status")
  knowledgeDoc    String?         @map("knowledge_doc") @db.Text
  lastAnalyzedAt  DateTime?       @map("last_analyzed_at")
  resolvedAt      DateTime?    @map("resolved_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  environmentId      String? @map("environment_id") @db.Uuid
  assignedOperatorId String? @map("assigned_operator_id") @db.Uuid

  client             Client              @relation(fields: [clientId], references: [id])
  system             System?             @relation(fields: [systemId], references: [id])
  environment        ClientEnvironment?  @relation(fields: [environmentId], references: [id], onDelete: Restrict)
  assignedOperator   Operator?           @relation(fields: [assignedOperatorId], references: [id], onDelete: SetNull)
  followers          TicketFollower[]
  events             TicketEvent[]
  artifacts          Artifact[]
  issueJobs           IssueJob[]
  devopsSyncState     DevOpsSyncState?
  systemAnalyses      SystemAnalysis[]
  ingestionRuns       IngestionRun[]
  emailProcessingLogs EmailProcessingLog[]
  pendingActions      PendingAction[]

  @@unique([clientId, ticketNumber])
  @@index([clientId, status])
  @@index([clientId, category])
  @@index([environmentId])
  @@index([assignedOperatorId])
  @@index([createdAt])
  @@map("tickets")
}

model TicketFollower {
  id           String       @id @default(uuid()) @db.Uuid
  ticketId     String       @map("ticket_id") @db.Uuid
  contactId    String       @map("contact_id") @db.Uuid
  followerType FollowerType @default(FOLLOWER) @map("follower_type")
  createdAt    DateTime     @default(now()) @map("created_at")

  ticket  Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([ticketId, contactId])
  @@index([contactId])
  @@map("ticket_followers")
}

model TicketEvent {
  id        String          @id @default(uuid()) @db.Uuid
  ticketId  String          @map("ticket_id") @db.Uuid
  eventType TicketEventType @map("event_type")
  content   String?
  metadata  Json?
  actor     String          @default("system")
  createdAt DateTime        @default(now()) @map("created_at")

  // Email dedup fields (only populated for EMAIL_INBOUND events)
  emailMessageId String? @unique @map("email_message_id") // RFC 822 Message-ID header
  emailHash      String? @unique @map("email_hash")       // SHA-256 of raw RFC822 source (fallback when Message-ID absent/unreliable)

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId, createdAt])
  @@map("ticket_events")
}

// --- Operational tasks (internal/business tasks, not tied to clients) ---

model OperationalTask {
  id          String                @id @default(uuid()) @db.Uuid
  subject     String
  description String?
  status      OperationalTaskStatus @default(OPEN)
  priority    Priority              @default(MEDIUM)
  source      OperationalTaskSource @default(MANUAL)
  externalRef String?               @map("external_ref")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  events          OperationalTaskEvent[]
  devopsSyncState DevOpsSyncState?

  @@index([status])
  @@index([createdAt])
  @@map("operational_tasks")
}

model OperationalTaskEvent {
  id        String                     @id @default(uuid()) @db.Uuid
  taskId    String                     @map("task_id") @db.Uuid
  eventType OperationalTaskEventType   @map("event_type")
  content   String?
  metadata  Json?
  actor     String                     @default("system")
  createdAt DateTime                   @default(now()) @map("created_at")

  task OperationalTask @relation(fields: [taskId], references: [id])

  @@index([taskId, createdAt])
  @@map("operational_task_events")
}

// --- Azure DevOps sync state ---

model DevOpsSyncState {
  id                String   @id @default(uuid()) @db.Uuid
  ticketId          String?  @unique @map("ticket_id") @db.Uuid
  operationalTaskId String?  @unique @map("operational_task_id") @db.Uuid
  workItemId        Int      @map("work_item_id")
  integrationId     String?  @map("integration_id")
  revision          Int      @default(0)
  lastCommentId     Int      @default(0) @map("last_comment_id")
  workItemType      String   @map("work_item_type")
  isActionable      Boolean  @default(false) @map("is_actionable")
  workflowState     String   @default("idle") @map("workflow_state")
  planJson          Json?    @map("plan_json")
  lastSyncedAt      DateTime @default(now()) @map("last_synced_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  ticket          Ticket?          @relation(fields: [ticketId], references: [id])
  operationalTask OperationalTask? @relation(fields: [operationalTaskId], references: [id])

  @@unique([workItemId, integrationId])
  @@index([workflowState])
  @@map("devops_sync_states")
}

// --- Artifacts & Findings ---

model Artifact {
  id          String   @id @default(uuid()) @db.Uuid
  ticketId    String?  @map("ticket_id") @db.Uuid
  findingId   String?  @map("finding_id") @db.Uuid
  filename    String
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  storagePath String   @map("storage_path")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  ticket  Ticket?  @relation(fields: [ticketId], references: [id])
  finding Finding? @relation(fields: [findingId], references: [id])

  @@map("artifacts")
}

model Finding {
  id             String        @id @default(uuid()) @db.Uuid
  systemId       String        @map("system_id") @db.Uuid
  title          String
  severity       Severity      @default(MEDIUM)
  category       String
  description    String
  recommendation String?
  sqlEvidence    String?       @map("sql_evidence")
  status         FindingStatus @default(OPEN)
  detectedAt     DateTime      @default(now()) @map("detected_at")
  resolvedAt     DateTime?     @map("resolved_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  system    System     @relation(fields: [systemId], references: [id])
  artifacts Artifact[]
  playbook  Playbook?

  @@index([systemId, status])
  @@map("findings")
}

model Playbook {
  id         String   @id @default(uuid()) @db.Uuid
  findingId  String?  @unique @map("finding_id") @db.Uuid
  title      String
  category   String
  content    String
  isTemplate Boolean  @default(false) @map("is_template")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  finding Finding? @relation(fields: [findingId], references: [id])

  @@map("playbooks")
}

// --- Audit ---

model QueryAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  systemId   String   @map("system_id") @db.Uuid
  query      String
  queryHash  String   @map("query_hash")
  toolName   String   @map("tool_name")
  caller     String
  durationMs Int?     @map("duration_ms")
  rowCount   Int?     @map("row_count")
  error      String?
  createdAt  DateTime @default(now()) @map("created_at")

  system System @relation(fields: [systemId], references: [id])

  @@index([systemId, createdAt])
  @@index([queryHash])
  @@map("query_audit_logs")
}

// --- Code Repos & Issue Resolution ---

model CodeRepo {
  id            String   @id @default(uuid()) @db.Uuid
  clientId      String   @map("client_id") @db.Uuid
  name          String
  repoUrl       String   @map("repo_url")
  defaultBranch String   @default("master") @map("default_branch")
  branchPrefix  String   @default("claude") @map("branch_prefix")
  description   String?  @map("description")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  environmentId String? @map("environment_id") @db.Uuid

  client      Client             @relation(fields: [clientId], references: [id])
  environment ClientEnvironment? @relation(fields: [environmentId], references: [id])
  issueJobs   IssueJob[]

  @@unique([clientId, repoUrl])
  @@index([environmentId])
  @@map("code_repos")
}

model IssueJob {
  id                    String         @id @default(uuid()) @db.Uuid
  ticketId              String         @map("ticket_id") @db.Uuid
  repoId                String         @map("repo_id") @db.Uuid
  branchName            String         @map("branch_name")
  status                IssueJobStatus @default(PENDING)
  plan                  Json?
  planRevision          Int            @default(0) @map("plan_revision")
  planFeedback          String?        @map("plan_feedback")
  approvedAt            DateTime?      @map("approved_at")
  approvedBy            String?        @map("approved_by")
  approvedByOperatorId  String?        @map("approved_by_operator_id") @db.Uuid
  commitSha             String?        @map("commit_sha")
  filesChanged          Int?           @map("files_changed")
  error                 String?
  aiModel               String?        @map("ai_model")
  aiUsage               Json?          @map("ai_usage")
  metadata              Json?
  startedAt             DateTime?      @map("started_at")
  completedAt           DateTime?      @map("completed_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  ticket            Ticket    @relation(fields: [ticketId], references: [id])
  repo              CodeRepo  @relation(fields: [repoId], references: [id])
  approvedByOperator Operator? @relation("ApprovedByOperator", fields: [approvedByOperatorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([repoId, status])
  @@map("issue_jobs")
}

// --- Ticket Status & Category Configs (editable from control panel Settings) ---
// Metadata for each TicketStatus / TicketCategory enum value: display name,
// description, color, sort order, and (for statuses) open/closed class.

model TicketStatusConfig {
  value       String   @id // Must match a TicketStatus enum value
  displayName String   @map("display_name")
  description String?
  color       String   @default("#757575")
  sortOrder   Int      @default(0) @map("sort_order")
  statusClass String   @default("open") @map("status_class") // "open" or "closed"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ticket_status_configs")
}

model TicketCategoryConfig {
  value       String   @id // Must match a TicketCategory enum value
  displayName String   @map("display_name")
  description String?
  color       String   @default("#757575")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ticket_category_configs")
}


// --- External Services (configurable from control panel Settings) ---

model ExternalService {
  id          String                   @id @default(uuid()) @db.Uuid
  name        String                   @unique // Display name, e.g. "Ollama (Local LLM)"
  endpoint    String                   // URL for HTTP/OLLAMA checks, container name for DOCKER
  checkType   ExternalServiceCheckType @default(HTTP) @map("check_type")
  isMonitored Boolean                  @default(true) @map("is_monitored")
  timeoutMs   Int                      @default(5000) @map("timeout_ms")
  notes       String?
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  @@map("external_services")
}

// --- Client Integrations (multi-client worker config) ---

model ClientIntegration {
  id        String          @id @default(uuid()) @db.Uuid
  clientId  String          @map("client_id") @db.Uuid
  type      IntegrationType
  label     String          @default("default") // e.g. "prod", "dev", "staging"
  config    Json
  metadata  Json?           @default("{}") // system-discovered data (tools, version, etc.)
  isActive  Boolean         @default(true) @map("is_active")
  notes     String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  environmentId String? @map("environment_id") @db.Uuid

  client      Client             @relation(fields: [clientId], references: [id])
  environment ClientEnvironment? @relation(fields: [environmentId], references: [id])
  scheduledProbes ScheduledProbe[]

  @@unique([clientId, type, label])
  @@index([environmentId])
  @@map("client_integrations")
}

// --- Application Logs ---

model AppLog {
  id         String   @id @default(uuid()) @db.Uuid
  level      LogLevel
  service    String
  message    String
  context    Json?
  entityId   String?  @map("entity_id") @db.Uuid
  entityType String?  @map("entity_type") // e.g. "ticket" or "operational_task"
  error      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([service, createdAt])
  @@index([level, createdAt])
  @@index([entityId, entityType])
  @@index([createdAt])
  @@map("app_logs")
}

// --- Log Summaries (AI-generated digests of application logs) ---

model LogSummary {
  id             String         @id @default(uuid()) @db.Uuid
  ticketId       String?        @map("ticket_id") @db.Uuid
  summaryType    LogSummaryType @default(SERVICE) @map("summary_type")
  attentionLevel AttentionLevel @default(NONE) @map("attention_level")
  windowStart    DateTime       @map("window_start")
  windowEnd      DateTime       @map("window_end")
  summary        String
  logCount       Int            @map("log_count")
  services       String[]       @default([])
  cursorLogIds   String[]       @default([]) @map("cursor_log_ids")
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([ticketId, windowStart])
  @@index([summaryType, windowStart])
  @@index([windowStart])
  @@index([createdAt])
  @@map("log_summaries")
}

// --- AI Usage Logs (tracks every AI generation call) ---

model AiUsageLog {
  id           String   @id @default(uuid()) @db.Uuid
  provider     String   // "LOCAL", "CLAUDE", "OPENAI", "GROK"
  model        String   // e.g. "llama3.1:8b", "claude-sonnet-4-5-20250929"
  taskType     String   @map("task_type")
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  durationMs   Int?     @map("duration_ms")
  costUsd      Float?   @map("cost_usd") // Computed from AiModelCost at write time
  entityId     String?  @map("entity_id") @db.Uuid
  entityType   String?  @map("entity_type") // e.g. "ticket" or "operational_task"
  clientId     String?  @map("client_id") @db.Uuid
  billingMode  String   @default("platform") @map("billing_mode")
  promptKey    String?  @map("prompt_key")
  promptText            String?  @map("prompt_text") @db.Text
  systemPrompt          String?  @map("system_prompt") @db.Text
  responseText          String?  @map("response_text") @db.Text
  conversationMetadata  Json?    @map("conversation_metadata")
  createdAt    DateTime @default(now()) @map("created_at")

  archive AiPromptArchive?

  @@index([provider, model, createdAt])
  @@index([entityId, entityType])
  @@index([clientId])
  @@index([createdAt])
  @@index([taskType])
  @@map("ai_usage_logs")
}

// --- AI Prompt Archives (full prompt/response text with retention) ---

model AiPromptArchive {
  id                    String    @id @default(uuid()) @db.Uuid
  usageLogId            String    @unique @map("usage_log_id") @db.Uuid
  fullPrompt            String    @map("full_prompt") @db.Text
  fullResponse          String    @map("full_response") @db.Text
  systemPrompt          String?   @map("system_prompt") @db.Text
  conversationMessages  Json?     @map("conversation_messages")
  totalContextTokens    Int?      @map("total_context_tokens")
  messageCount          Int?      @map("message_count")
  summarizedAt          DateTime? @map("summarized_at")
  summary               String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")

  usageLog AiUsageLog @relation(fields: [usageLogId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([summarizedAt])
  @@map("ai_prompt_archives")
}

// --- Invoices (per-client AI usage billing) ---

model Invoice {
  id                 String   @id @default(uuid()) @db.Uuid
  clientId           String   @map("client_id") @db.Uuid
  invoiceNumber      Int      @map("invoice_number")
  periodStart        DateTime @map("period_start")
  periodEnd          DateTime @map("period_end")
  totalBaseCostUsd   Decimal  @map("total_base_cost_usd")
  totalBilledCostUsd Decimal  @map("total_billed_cost_usd")
  totalInputTokens   Int      @default(0) @map("total_input_tokens")
  totalOutputTokens  Int      @default(0) @map("total_output_tokens")
  requestCount       Int      @default(0) @map("request_count")
  markupPercent      Decimal  @map("markup_percent")
  pdfPath            String?  @map("pdf_path")
  status             String   @default("draft") // "draft" | "final"
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, invoiceNumber])
  @@index([clientId, periodStart])
  @@map("invoices")
}

// --- AI Model Costs (per-model pricing for cost tracking) ---

model AiModelCost {
  id                      String   @id @default(uuid()) @db.Uuid
  provider                String   // "LOCAL", "CLAUDE", "OPENAI", "GROK", "GOOGLE"
  model                   String   // e.g. "claude-sonnet-4-6", "gpt-4.1"
  displayName             String?  @map("display_name") // Human-readable name
  description             String?  @db.Text // Model description from provider
  inputCostPer1m          Float    @default(0) @map("input_cost_per_1m")  // USD per 1M input tokens
  outputCostPer1m         Float    @default(0) @map("output_cost_per_1m") // USD per 1M output tokens
  contextLength           Int?     @map("context_length") // Max context window in tokens
  maxCompletionTokens     Int?     @map("max_completion_tokens") // Max output tokens
  modality                String?  // e.g. "text+image->text", "text->text"
  isCustomCost            Boolean  @default(false) @map("is_custom_cost") // Custom pricing overrides API-fetched pricing
  isActive                Boolean  @default(true) @map("is_active")
  updatedAt               DateTime @updatedAt @map("updated_at")
  createdAt               DateTime @default(now()) @map("created_at")

  @@unique([provider, model])
  @@index([provider])
  @@map("ai_model_costs")
}

// --- AI Providers (one row per provider type — LOCAL, CLAUDE, OPENAI, GROK, GOOGLE) ---
// Stores connection settings and API keys for each LLM provider.
// API keys are encrypted at rest via AES-256-GCM.

model AiProvider {
  id              String   @id @default(uuid()) @db.Uuid
  provider        String   @unique // "LOCAL", "CLAUDE", "OPENAI", "GROK", "GOOGLE"
  baseUrl         String?  @map("base_url")
  encryptedApiKey String?  @map("encrypted_api_key")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  models AiProviderModel[]

  @@map("ai_providers")
}

// --- AI Provider Models (1:many from AiProvider) ---
// Each model belongs to a provider and carries its own capability level,
// app scope restrictions, and active flag.

model AiProviderModel {
  id              String   @id @default(uuid()) @db.Uuid
  providerId      String   @map("provider_id") @db.Uuid
  name            String   @unique // Human-readable label, e.g. "Claude Sonnet Production"
  model           String   // Model identifier, e.g. "claude-sonnet-4-6", "llama3.1:8b"
  capabilityLevel String   @default("STANDARD") @map("capability_level")
  isActive        Boolean  @default(true) @map("is_active")
  enabledApps     String[] @default([]) @map("enabled_apps") // AppScope values; empty = all apps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  provider AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([capabilityLevel, isActive])
  @@map("ai_provider_models")
}

// --- AI Model Configuration (per-task provider/model overrides) ---
// Stores which AI provider + model to use for each TaskType.
// APP_WIDE configs are system-wide defaults; CLIENT-scoped configs override per client.
// When no config exists for a task type, the hardcoded defaults in ai-provider apply.

model AiModelConfig {
  id        String        @id @default(uuid()) @db.Uuid
  taskType  String        @map("task_type")
  scope     OverrideScope @default(APP_WIDE)
  clientId  String?       @map("client_id") @db.Uuid
  provider  String        // "LOCAL" or "CLAUDE"
  model     String        // e.g. "llama3.1:8b", "claude-sonnet-4-5-20250929"
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  client Client? @relation(fields: [clientId], references: [id])

  @@unique([taskType, scope, clientId])
  @@index([taskType])
  @@index([clientId])
  @@map("ai_model_configs")
}

// --- AI Prompt Overrides (editable from control panel) ---
// Base prompts are hardcoded in packages/ai-provider/src/prompts/.
// Overrides add app-wide or per-client text that is prepended/appended.

model PromptOverride {
  id        String        @id @default(uuid()) @db.Uuid
  promptKey String        @map("prompt_key") // FK to hardcoded prompt key, e.g. "imap.triage.system"
  scope     OverrideScope @default(APP_WIDE)
  clientId  String?       @map("client_id") @db.Uuid // Required when scope = CLIENT
  position  OverridePosition @default(APPEND)
  content   String        // Additional text to prepend/append
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  client Client? @relation(fields: [clientId], references: [id])

  @@unique([promptKey, scope, clientId]) // One override per prompt per scope per client
  @@index([promptKey])
  @@index([clientId])
  @@map("prompt_overrides")
}

model PromptKeyword {
  id          String @id @default(uuid()) @db.Uuid
  token       String @unique // Placeholder name, e.g. "recipientName"
  label       String // Human-readable, e.g. "Recipient Name"
  description String // What this keyword represents
  sampleValue String? @map("sample_value") // Example value for preview
  category    String // Grouping: TICKET, EMAIL, DEVOPS, CODE, DATABASE, GENERAL
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("prompt_keywords")
}

// --- System Analysis (AI-generated improvement suggestions from closed tickets) ---

model SystemAnalysis {
  id              String               @id @default(uuid()) @db.Uuid
  ticketId        String?              @map("ticket_id") @db.Uuid
  clientId        String               @map("client_id") @db.Uuid
  status          SystemAnalysisStatus @default(PENDING)
  triggerType     SystemAnalysisTriggerType @default(TICKET_CLOSE) @map("trigger_type")
  analysis        String               // AI-generated analysis of the ticket lifecycle
  suggestions     String               // AI-suggested system improvements
  rejectionReason String?              @map("rejection_reason")
  aiModel         String?              @map("ai_model")
  aiProvider      String?              @map("ai_provider")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  ticket Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id])

  @@index([status])
  @@index([clientId])
  @@index([ticketId])
  @@index([createdAt])
  @@map("system_analyses")
}

